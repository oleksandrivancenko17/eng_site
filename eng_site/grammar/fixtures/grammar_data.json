    "model": "grammar.grammartopic", "pk": 1,
    "fields": {
      "title": "Present Simple", "level": "A1",
      "theory": "Використовується для регулярних дій, звичок та загальновідомих фактів. Зі займенниками he, she, it до дієслова додається закінчення -s/-es."
    }
  },
  {
    "model": "grammar.grammartopic", "pk": 2,
    "fields": {
      "title": "Past Simple", "level": "A1",
      "theory": "Використовується для дій, які завершилися в минулому. Для правильних дієслів додаємо -ed, для неправильних використовуємо другу форму (V2)."
    }
  },
  {
    "model": "grammar.grammartopic", "pk": 3,
    "fields": {
      "title": "Present Continuous", "level": "A2",
      "theory": "Використовується для дій, які відбуваються прямо зараз. Утворюється за допомогою дієслова to be (am/is/are) та дієслова із закінченням -ing."
    }
  },
  {
    "model": "grammar.grammartopic", "pk": 4,
    "fields": {
      "title": "Present Perfect", "level": "B1",
      "theory": "Використовується для дій, які відбулися в минулому, але їхній результат важливий зараз. Утворюється: have/has + третя форма дієслова (V3/-ed)."
    }
  },

